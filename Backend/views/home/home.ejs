<% layout('/layouts/boilerplate') %>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="hero-title">Find your next perfect stay</h1>
        <p class="hero-subtitle">Discover unique homes, cozy cabins, beachfronts and more — all in one place.</p>
        <a href="/listing" class="hero-btn">Explore Listings</a>
    </div>
</section>

<!-- Features Section -->
<section class="features">
    <div class="container">
        <h2 class="features-heading">Why Hostly?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fa-solid fa-house"></i>
                    </div>
                    <h5 class="feature-title">Unique Places</h5>
                    <p class="feature-desc">From cozy cottages to luxury villas, find a place that fits your style and budget.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <h5 class="feature-title">Trusted Listings</h5>
                    <p class="feature-desc">Every listing is verified and reviewed so you can book with confidence.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fa-solid fa-earth-asia"></i>
                    </div>
                    <h5 class="feature-title">Worldwide Locations</h5>
                    <p class="feature-desc">Explore destinations across continents — beaches, mountains, cities and more.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="cta-content">
        <h2 class="cta-title">Have a place to share?</h2>
        <p class="cta-desc">List your property on Hostly and reach thousands of travellers looking for their next stay.</p>
        <a href="/listing/new" class="cta-btn">Create a Listing</a>
    </div>
</section>
